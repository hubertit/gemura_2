# Gemura deployment credentials (do not commit this file)
# Setup:
#   cp server-credentials.sh.example server-credentials.sh
#   chmod 600 server-credentials.sh
#   Edit server-credentials.sh and set SERVER_PASS (and SERVER_IP/SERVER_USER if different)
#
# Example (replace with your actual values):
#   SERVER_IP="209.74.80.195"
#   SERVER_USER="root"
#   SERVER_PASS="your_password_here"
#   export SERVER_IP SERVER_USER SERVER_PASS
#
# Optional – for Nginx + Let's Encrypt (setup-nginx-domains.sh):
#   CERTBOT_EMAIL="admin@gemura.rw"
#   export CERTBOT_EMAIL
